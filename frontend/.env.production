# VITE_REVERB_HOST=auto → uses window.location.hostname at runtime
# No need to hardcode the VPS IP — it resolves automatically
VITE_REVERB_HOST=auto
VITE_REVERB_PORT=80
VITE_REVERB_SCHEME=http

# Empty → uses relative URL /broadcasting/auth (same origin as the page)
VITE_API_URL=

# Must match REVERB_APP_KEY from .env on the VPS.
# deploy.sh injects this automatically from .env — no need to edit manually.
VITE_REVERB_APP_KEY=
