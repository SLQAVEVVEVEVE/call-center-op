APP_NAME=CallCenterOp
APP_ENV=production
APP_DEBUG=false
# Run: docker compose exec app php artisan key:generate --show
APP_KEY=
APP_URL=

DB_HOST=mysql
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Token from BotFather
TELEGRAM_TOKEN=

# Run: openssl rand -hex 8
REVERB_APP_ID=
# Run: openssl rand -hex 16  — copy this value to frontend/.env.production as VITE_REVERB_APP_KEY
REVERB_APP_KEY=
# Run: openssl rand -hex 16
REVERB_APP_SECRET=
# Use 0.0.0.0 on VPS (binds to all interfaces inside the container)
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
BROADCAST_CONNECTION=reverb

CACHE_STORE=file
